{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=YOUR_DATABASE;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JWT": {
    "Key": "YOUR_SUPER_SECRET_JWT_KEY_HERE_MIN_32_CHARS",
    "Issuer": "SercureApi",
    "Audience": "SercureApiUser",
    "DurationInDays": 30
  },
  "EmailSettings": {
    "Host": "smtp.gmail.com",
    "Port": 587,
    "EnableSsl": true,
    "SenderName": "GlobalPOS Support",
    "SenderEmail": "your-email@gmail.com",
    "Username": "your-email@gmail.com",
    "Password": "your-app-password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "UserRoles": [
    {
      "RoleName": "Admin",
      "Description": "يرى كل الفروع والمخازن. يدير كل البيانات. يدير المستخدمين. يراجع التقارير."
    },
    {
      "RoleName": "BranchManager",
      "Description": "يدير الفرع المرتبط به فقط. يرى مخزون الفرع والتحويلات والجرد والعمليات الخاصة بفرعه."
    },
    {
      "RoleName": "WarehouseManager",
      "Description": "يدير المخزن المرتبط به فقط. يعتمد التحويلات والتجهيزات والتصنيع والجرد داخل مخزنه."
    },
    {
      "RoleName": "Cashier",
      "Description": "يشتغل على جزء الكاشير فقط داخل الفرع. لا يدير المخزون بالكامل."
    },
    {
      "RoleName": "WarehouseWorker",
      "Description": "يشتغل على العمليات اليومية للمخزن. مثل تجهيز الطلبات، الاستلام، الجرد، إدخال الحركات حسب الصلاحية."
    }
  ]
}
